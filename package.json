{
  "name": "@typetype/mse",
  "version": "0.1.2",
  "description": "MSE playback engine for TypeType",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Priveetee/TypeType-Player.git"
  },
  "homepage": "https://github.com/Priveetee/TypeType-Player#readme",
  "bugs": {
    "url": "https://github.com/Priveetee/TypeType-Player/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:types && bun build src/index.ts --target browser --format esm --outfile dist/index.js",
    "build:types": "tsc --emitDeclarationOnly",
    "check": "biome check . && tsc --noEmit",
    "check:docs": "deno doc --lint src/index.ts",
    "check:jsr": "deno publish --dry-run --allow-dirty",
    "check:versions": "node --eval 'const npmPackage = require(\"./package.json\"); const jsrPackage = require(\"./jsr.json\"); if (npmPackage.version !== jsrPackage.version) process.exit(1)'",
    "clean": "bun --eval 'import { rmSync } from \"node:fs\"; rmSync(\"dist\", { recursive: true, force: true })'",
    "format": "biome format --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "prepack": "bun run build",
    "publish:jsr": "deno publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "typescript": "~6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
