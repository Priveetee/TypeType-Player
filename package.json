{
  "name": "@typetype/mse",
  "version": "0.1.0",
  "description": "MSE playback engine for TypeType",
  "license": "MIT",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build:types && bun build src/index.ts --target browser --format esm --outfile dist/index.js",
    "build:types": "tsc --emitDeclarationOnly",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "typescript": "^5.9.2"
  }
}
